# ─── GestorNominas — Variables de entorno ────────────────────────
# Copia este archivo como .env y ajusta los valores según tu entorno.

# Puerto del servidor backend
PORT=3001

# Entorno: development | production | test
NODE_ENV=development

# Origen permitido para CORS (URL del frontend)
CORS_ORIGIN=http://localhost:4321

# Ruta a la base de datos SQLite (relativa al directorio backend/)
DATABASE_PATH=../data/nominas.db

# Directorio donde se almacenan los PDFs subidos (relativo al directorio backend/)
UPLOAD_DIR=../data/uploads

# Secreto para firmar tokens JWT (mínimo 32 caracteres en producción)
JWT_SECRET=change-me-to-a-strong-random-secret-at-least-32-chars

# Tiempo de expiración de los tokens JWT
JWT_EXPIRES_IN=7d
