# ─── Gestor de Nóminas ───────────────────────────────────────────
# Copy this file to .env and fill in the values

# REQUIRED: Set a strong secret for JWT tokens (min 16 chars)
JWT_SECRET=change-me-to-a-strong-random-secret-at-least-32-chars

# Optional
PORT=3001
CORS_ORIGIN=http://localhost:3001
JWT_EXPIRES_IN=7d
