---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
  { href: "/", label: "Dashboard", icon: "chart" },
  { href: "/upload", label: "Subir Nóminas", icon: "upload" },
  { href: "/payslips", label: "Mis Nóminas", icon: "file" },
  { href: "/analytics", label: "Analítica", icon: "analytics" },
  { href: "/profiles", label: "Perfiles", icon: "users" },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Gestor de Nóminas</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-surface-50">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="hidden md:flex w-[260px] flex-col bg-white border-r border-surface-200 fixed inset-y-0 left-0 z-30">
        <!-- Logo -->
        <div class="flex items-center gap-3 px-6 h-16 border-b border-surface-200">
          <div class="w-8 h-8 rounded-lg bg-primary-600 flex items-center justify-center">
            <svg class="w-4.5 h-4.5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
          </div>
          <div>
            <h1 class="text-sm font-bold text-surface-900 leading-tight">Gestor Nóminas</h1>
            <p class="text-[11px] text-surface-400 leading-tight">Panel de control</p>
          </div>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
          {navItems.map((item) => {
            const isActive = currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href));
            return (
              <a
                href={item.href}
                class:list={[
                  "group flex items-center gap-3 px-3 py-2.5 rounded-xl text-[13px] font-medium transition-all duration-150 cursor-pointer",
                  isActive
                    ? "bg-primary-50 text-primary-700 shadow-sm"
                    : "text-surface-600 hover:bg-surface-100 hover:text-surface-900",
                ]}
              >
                {item.icon === "chart" && (
                  <svg class:list={["w-[18px] h-[18px] transition-colors", isActive ? "text-primary-600" : "text-surface-400 group-hover:text-surface-600"]} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/>
                  </svg>
                )}
                {item.icon === "upload" && (
                  <svg class:list={["w-[18px] h-[18px] transition-colors", isActive ? "text-primary-600" : "text-surface-400 group-hover:text-surface-600"]} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>
                  </svg>
                )}
                {item.icon === "file" && (
                  <svg class:list={["w-[18px] h-[18px] transition-colors", isActive ? "text-primary-600" : "text-surface-400 group-hover:text-surface-600"]} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 13H8"/><path d="M16 17H8"/><path d="M16 13h-2"/>
                  </svg>
                )}
                {item.icon === "users" && (
                  <svg class:list={["w-[18px] h-[18px] transition-colors", isActive ? "text-primary-600" : "text-surface-400 group-hover:text-surface-600"]} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                  </svg>
                )}
                {item.icon === "analytics" && (
                  <svg class:list={["w-[18px] h-[18px] transition-colors", isActive ? "text-primary-600" : "text-surface-400 group-hover:text-surface-600"]} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/><ellipse cx="12" cy="5" rx="9" ry="3"/>
                  </svg>
                )}
                <span>{item.label}</span>
              </a>
            );
          })}
        </nav>

        <!-- Footer -->
        <div class="px-4 py-3 border-t border-surface-200 space-y-2">
          <button
            id="theme-toggle"
            class="w-full flex items-center gap-2 px-3 py-2 rounded-xl text-[12px] font-medium text-surface-500 hover:bg-surface-100 hover:text-surface-700 transition"
            aria-label="Cambiar tema"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
            </svg>
            <span>Modo oscuro</span>
          </button>
          <p class="text-[11px] text-surface-400 text-center">v2.0 · Datos locales</p>
        </div>
      </aside>

      <!-- Mobile header -->
      <header class="md:hidden fixed top-0 left-0 right-0 h-14 bg-white border-b border-surface-200 z-30 flex items-center px-4 gap-3">
        <div class="w-7 h-7 rounded-lg bg-primary-600 flex items-center justify-center flex-shrink-0">
          <svg class="w-3.5 h-3.5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
          </svg>
        </div>
        <span class="text-sm font-bold text-surface-900">Gestor Nóminas</span>
      </header>

      <!-- Mobile bottom nav -->
      <nav class="md:hidden fixed bottom-0 left-0 right-0 h-16 bg-white border-t border-surface-200 z-30 flex items-center justify-around px-2">
        {navItems.map((item) => {
          const isActive = currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href));
          return (
            <a
              href={item.href}
              class:list={[
                "flex flex-col items-center gap-1 px-3 py-1.5 rounded-lg transition-colors cursor-pointer",
                isActive ? "text-primary-600" : "text-surface-400",
              ]}
            >
              {item.icon === "chart" && (
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/>
                </svg>
              )}
              {item.icon === "upload" && (
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>
                </svg>
              )}
              {item.icon === "file" && (
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/>
                </svg>
              )}
              {item.icon === "users" && (
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                </svg>
              )}
              {item.icon === "analytics" && (
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/><ellipse cx="12" cy="5" rx="9" ry="3"/>
                </svg>
              )}
              <span class="text-[10px] font-medium">{item.label.split(" ")[0]}</span>
            </a>
          );
        })}
      </nav>

      <!-- Main content -->
      <main class="flex-1 md:ml-[260px] mt-14 md:mt-0 mb-16 md:mb-0 overflow-auto min-h-screen">
        <div class="px-4 py-6 md:px-8 md:py-8 max-w-7xl mx-auto">
          <slot />
        </div>
      </main>
    </div>

    <script is:inline>
      // Dark mode toggle
      (function() {
        const html = document.documentElement;
        const stored = localStorage.getItem("theme");
        if (stored === "dark" || (!stored && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
          html.classList.add("dark");
        }

        function updateToggle() {
          const isDark = html.classList.contains("dark");
          const btn = document.getElementById("theme-toggle");
          if (!btn) return;
          const label = btn.querySelector("span");
          const svg = btn.querySelector("svg");
          if (label) label.textContent = isDark ? "Modo claro" : "Modo oscuro";
          if (svg) svg.innerHTML = isDark
            ? '<circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/>'
            : '<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>';
        }

        updateToggle();

        document.addEventListener("click", function(e) {
          if (e.target && e.target.closest("#theme-toggle")) {
            html.classList.toggle("dark");
            localStorage.setItem("theme", html.classList.contains("dark") ? "dark" : "light");
            updateToggle();
          }
        });
      })();
    </script>
  </body>
</html>
